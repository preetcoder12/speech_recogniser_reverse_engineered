<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.android.settingslib.widget.TopIntroPreference
        android:title="@string/offline_transcription_settings_summary" />
    <com.android.settingslib.widget.BannerMessagePreference
        android:icon="@drawable/quantum_gm_ic_cancel_black_24"
        android:textSize="@dimen/downloaded_languages_settings_unavailable_message_text_size"
        android:key="@string/pref_downloaded_languages_settings_unavailable"
        android:summary="@string/downloaded_languages_settings_languages_unavailable_tips"
        app:isPreferenceVisible="false" />
    <com.android.settingslib.widget.MainSwitchPreference
        android:title="@string/downloaded_languages_settings_toggle_title"
        android:key="@string/pref_offline_transcription"
        android:defaultValue="@bool/pref_default_offline_transcription"
        app:iconSpaceReserved="false"
        app:isPreferenceVisible="false" />
    <PreferenceCategory
        android:title="@string/primary_language_title"
        app:iconSpaceReserved="false">
        <com.google.audio.hearing.visualization.accessibility.scribe.common.ui.LanguageItemPreference
            android:key="@string/pref_primary_language"
            app:iconSpaceReserved="false" />
    </PreferenceCategory>
    <PreferenceCategory
        android:title="@string/secondary_language_title"
        android:key="@string/secondary_language_title"
        app:iconSpaceReserved="false">
        <com.google.audio.hearing.visualization.accessibility.scribe.common.ui.LanguageItemPreference
            android:key="@string/pref_secondary_language"
            app:iconSpaceReserved="false" />
    </PreferenceCategory>
    <com.android.settingslib.widget.FooterPreference
        android:title="@string/offline_transcription_settings_footer" />
</PreferenceScreen>