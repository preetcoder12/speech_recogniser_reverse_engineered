<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:id="@id/transcription_error_mic_container"
    android:visibility="gone"
    android:clickable="false"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <TextView
        android:textAppearance="?textAppearanceBody2"
        android:textColor="@color/speaking_animation_title_color"
        android:id="@id/text_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:importantForAccessibility="no"
        android:textAlignment="center" />
    <ImageView
        android:id="@id/start_speaking_image"
        android:layout_width="@dimen/microphone_animation_size"
        android:layout_height="@dimen/microphone_animation_size"
        android:src="@drawable/microphone_off" />
</LinearLayout>