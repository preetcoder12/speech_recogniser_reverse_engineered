<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:theme="@style/Theme.GoogleMaterial3.DayNight"
    android:orientation="vertical"
    android:background="@color/scribe_frame_background"
    android:clipChildren="true"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:textSize="http://schemas.android.com/apk/res-auto">
    <com.google.audio.hearing.visualization.accessibility.scribe.ui.settings.PtzLinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_weight="1.0">
        <androidx.core.widget.NestedScrollView
            android:id="@id/preview_text_scroll"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_marginTop="@dimen/preview_text_scroll_margin"
            android:fillViewport="true"
            android:contentDescription="@string/text_size_preview_text_footer_summary"
            android:layout_marginStart="@dimen/preview_text_scroll_margin"
            android:layout_marginEnd="@dimen/preview_text_scroll_margin">
            <TextView
                android:id="@id/preview_text"
                android:background="@color/scribe_window_background"
                android:paddingTop="@dimen/preview_textview_padding"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/preview_textview_height"
                android:fontFamily="@font/google_sans"
                android:textDirection="locale"
                android:paddingStart="@dimen/preview_textview_padding"
                android:paddingEnd="@dimen/preview_textview_padding" />
        </androidx.core.widget.NestedScrollView>
    </com.google.audio.hearing.visualization.accessibility.scribe.ui.settings.PtzLinearLayout>
    <TextView
        android:textAppearance="?textAppearanceHeadline6"
        android:gravity="start|center"
        android:layout_width="fill_parent"
        android:layout_height="?android:actionBarSize"
        android:minHeight="72.0dip"
        android:text="@string/text_size_preview_text_footer_summary"
        android:importantForAccessibility="no"
        android:paddingStart="32.0dip" />
    <LinearLayout
        android:orientation="vertical"
        android:background="?android:windowBackground"
        android:paddingTop="16.0dip"
        android:paddingBottom="16.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingStart="?android:listPreferredItemPaddingStart"
        android:paddingEnd="?android:listPreferredItemPaddingEnd">
        <com.google.audio.hearing.visualization.accessibility.scribe.common.ui.TextSizeLinearLayout
            android:gravity="center_vertical"
            android:id="@id/text_size_container"
            android:paddingTop="8.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            textSize:defaultTextSizeIndex="@integer/default_text_size_index"
            textSize:spKey="@string/pref_text_size"
            textSize:textSizeEntries="@array/text_size_entries"
            textSize:textSizeValues="@array/text_size_values">
            <ImageView
                android:id="@id/smaller"
                android:background="?android:selectableItemBackgroundBorderless"
                android:focusable="true"
                android:layout_width="48.0dip"
                android:layout_height="48.0dip"
                android:src="@drawable/ic_font_size_16dp"
                android:scaleType="center"
                android:tint="?android:textColorPrimary"
                android:contentDescription="@string/make_smaller_text_size_description"
                android:tintMode="src_in" />
            <com.google.android.material.slider.Slider
                android:theme="@style/Theme.MaterialComponents.DayNight"
                android:id="@id/text_size_slider"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:maxHeight="@dimen/text_size_slider_height"
                android:minHeight="@dimen/text_size_slider_height"
                android:layout_weight="1.0"
                android:contentDescription="@string/text_size_title"
                android:paddingStart="20.0dip"
                android:paddingEnd="20.0dip"
                style="@style/SettingslibSliderStyle.Expressive" />
            <ImageView
                android:id="@id/larger"
                android:background="?android:selectableItemBackgroundBorderless"
                android:focusable="true"
                android:layout_width="48.0dip"
                android:layout_height="48.0dip"
                android:src="@drawable/ic_font_size_24dp"
                android:scaleType="center"
                android:tint="?android:textColorPrimary"
                android:contentDescription="@string/make_larger_text_size_description"
                android:tintMode="src_in" />
        </com.google.audio.hearing.visualization.accessibility.scribe.common.ui.TextSizeLinearLayout>
    </LinearLayout>
</LinearLayout>