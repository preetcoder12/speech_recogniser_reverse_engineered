<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/type_back_container"
    android:background="?typeBackBackgroundColor"
    android:visibility="gone"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:elevation="0.0dip"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/type_back_divider"
        android:background="?scribeDividerColor"
        android:clickable="false"
        android:layout_width="fill_parent"
        android:layout_height="1.0dip"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <ScrollView
        android:id="@id/type_back_scrollbar"
        android:scrollbars="none"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button_container"
        app:layout_constraintVertical_weight="1.0">
        <EditText
            android:enabled="true"
            android:textAppearance="?textAppearanceHeadline6"
            android:textColor="?android:textColorPrimary"
            android:textColorHint="@color/edit_text_hint_color"
            android:gravity="top"
            android:id="@id/type_back_edit_text"
            android:background="?typeBackBackgroundColor"
            android:paddingLeft="@dimen/text_view_margin"
            android:paddingRight="@dimen/text_view_margin"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:hint="@string/typeback_hint"
            android:inputType="textFilter|textMultiLine"
            android:imeOptions="flagNoExtractUi|flagNoFullscreen" />
    </ScrollView>
    <HorizontalScrollView
        android:id="@id/button_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/type_back_divider">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:paddingTop="@dimen/type_back_button_container_padding_top"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingEnd="@dimen/type_back_button_container_padding_end">
            <com.google.audio.hearing.visualization.accessibility.scribe.ui.typeback.TypeBackViewButton
                android:id="@id/clear_input"
                android:text="@string/clear_input_title"
                android:contentDescription="@string/type_back_clear_text_long_press_desc"
                app:icon="@drawable/gs_delete_vd_theme_24"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tts_button"
                style="@style/TypeBackButtonTheme" />
            <com.google.audio.hearing.visualization.accessibility.scribe.ui.typeback.TypeBackViewButton
                android:enabled="false"
                android:id="@id/tts_button"
                android:text="@string/tts_speak_title"
                android:contentDescription="@string/type_back_tts_long_press_desc"
                app:icon="@drawable/gs_volume_up_vd_theme_24"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/type_back_text_visibility"
                style="@style/TypeBackButtonTheme" />
            <com.google.audio.hearing.visualization.accessibility.scribe.ui.typeback.TypeBackViewButton
                android:id="@id/type_back_text_visibility"
                android:visibility="gone"
                android:text="@string/show_text_title"
                android:contentDescription="@string/type_back_hide_outside_screen_long_press_desc"
                app:icon="@drawable/type_back_text_visible"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/dual_display_button"
                style="@style/TypeBackButtonTheme" />
            <com.google.audio.hearing.visualization.accessibility.scribe.ui.typeback.TypeBackViewButton
                android:id="@id/dual_display_button"
                android:text="@string/dual_display_mode"
                android:contentDescription="@string/type_back_dual_screen_inactive_long_press_desc"
                app:icon="@drawable/gs_dual_screen_vd_theme_24"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/type_back_text_visibility"
                style="@style/TypeBackButtonTheme" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </HorizontalScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>