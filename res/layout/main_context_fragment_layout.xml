<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    android:theme="@style/Theme.MaterialComponents.DayNight"
    android:id="@id/main_container_scroll_view"
    android:scrollbars="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:fadeScrollbars="true"
    android:paddingHorizontal="@dimen/main_context_frag_layout_padding_hz"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/main_control_container"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <include
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/main_context_frag_switch_margin_top"
                android:layout_marginBottom="@dimen/main_context_frag_switch_margin_bottom"
                layout="@layout/dolphin_switch_material" />
            <include
                layout="@layout/select_sound_type_btn" />
        </LinearLayout>
        <android.support.v7.widget.RecyclerView
            android:id="@id/detected_sound_list_view"
            android:scrollbars="none"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <include
            layout="@layout/try_a_demo_layout" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>