<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:elevation="@dimen/abc_action_bar_elevation_material">
        <com.google.audio.hearing.visualization.accessibility.scribe.ui.loudness.LoudnessIndicatorToolTipView
            android:layout_gravity="end|center|top"
            android:id="@id/tips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <Button
            android:textAppearance="?textAppearanceButton"
            android:textColor="?colorAccent"
            android:layout_gravity="end|center|top"
            android:id="@id/got_it"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/got_it_marginTop"
            android:text="@string/got_it"
            android:layout_marginEnd="@dimen/got_it_marginEnd" />
    </FrameLayout>
</FrameLayout>