<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:id="@id/transcript_info"
    android:background="?android:selectableItemBackground"
    android:paddingTop="@dimen/search_list_item_padding_top"
    android:paddingBottom="@dimen/search_list_item_padding_bottom"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/search_list_item_padding_start"
    android:paddingEnd="@dimen/search_list_item_padding_end"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <TextView
        android:textColor="?android:textColorPrimary"
        android:ellipsize="end"
        android:id="@id/content"
        android:paddingBottom="@dimen/search_list_item_padding_bottom"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
    <TextView
        android:textColor="?android:textColorSecondary"
        android:layout_gravity="start|center"
        android:id="@id/timestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:layout_below="@id/content" />
</RelativeLayout>