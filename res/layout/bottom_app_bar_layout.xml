<?xml version="1.0" encoding="utf-8"?>
<com.google.audio.hearing.visualization.accessibility.scribe.ui.ScribeBottomAppBar
    android:layout_gravity="bottom"
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    app:backgroundTint="?bottomAppBarPrimaryColor"
    style="Widget.Material3.DockedToolbar"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@id/speaker_registration_container"
            android:padding="@dimen/registration_container_padding"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="?actionBarSize"
            android:layout_marginHorizontal="@dimen/action_menu_view_margin_horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@id/bottom_menu_settings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/settings_title"
                android:tooltipText="@string/settings_title"
                app:backgroundTint="?bottomAppBarPrimaryColor"
                app:icon="@drawable/quantum_ic_settings_googblue_24"
                app:iconTint="?colorAccent"
                style="?materialIconButtonStyle" />
            <com.google.android.material.button.MaterialButton
                android:id="@id/type_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/type_back_title"
                android:tooltipText="@string/type_back_title"
                app:backgroundTint="?bottomAppBarPrimaryColor"
                app:icon="@drawable/quantum_ic_keyboard_googblue_24"
                app:iconTint="?colorAccent"
                style="?materialIconButtonStyle" />
            <com.google.android.material.button.MaterialButton
                android:id="@id/cast_media_button"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/cast_media_button_title"
                android:tooltipText="@string/cast_media_button_title"
                app:backgroundTint="?bottomAppBarPrimaryColor"
                app:iconTint="?colorAccent"
                style="?materialIconButtonStyle" />
            <com.google.android.material.button.MaterialButton
                android:id="@id/dual_display"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/type_back_dual_screen_inactive_long_press_desc"
                android:tooltipText="@string/type_back_dual_screen_inactive_long_press_desc"
                app:backgroundTint="?bottomAppBarPrimaryColor"
                app:icon="@drawable/dual_display_stopped"
                app:iconTint="?colorAccent"
                style="?materialIconButtonStyle" />
            <com.google.android.material.button.MaterialButton
                android:id="@id/hold_transcription"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/hold_transcription"
                android:tooltipText="@string/hold_transcription"
                app:backgroundTint="?bottomAppBarPrimaryColor"
                app:icon="@drawable/ic_hold_off_24dp"
                app:iconTint="?colorAccent"
                style="?materialIconButtonStyle" />
            <include
                android:id="@id/language_button"
                android:contentDescription="@string/secondary_language_title"
                layout="@layout/language_menu_item_layout" />
        </LinearLayout>
    </LinearLayout>
</com.google.audio.hearing.visualization.accessibility.scribe.ui.ScribeBottomAppBar>