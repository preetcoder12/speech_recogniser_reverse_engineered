<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:paddingTop="@dimen/custom_sounds_dialog_title_padding"
    android:paddingBottom="@dimen/custom_sounds_dialog_title_bottom_padding"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:paddingStart="@dimen/custom_sounds_dialog_title_padding"
    android:paddingEnd="@dimen/custom_sounds_dialog_title_padding"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <TextView
        android:ellipsize="end"
        android:gravity="center_horizontal"
        android:id="@id/dialog_title"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:singleLine="false"
        style="?android:textAppearanceLarge" />
</LinearLayout>