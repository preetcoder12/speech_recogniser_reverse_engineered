<?xml version="1.0" encoding="utf-8"?>
<selector
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_checked="false">
        <shape>
            <corners
                android:radius="@dimen/rounded_button_radius" />
            <stroke
                android:width="@dimen/rounded_button_stroke_width"
                android:color="@color/dolphin_color_accent_secondary" />
            <solid
                android:color="@color/dolphin_color_accent_secondary" />
        </shape>
    </item>
    <item
        android:state_checked="true">
        <shape>
            <corners
                android:radius="@dimen/rounded_button_radius" />
            <stroke
                android:width="@dimen/rounded_button_stroke_width"
                android:color="@color/dolphin_color_accent_primary" />
            <solid
                android:color="@color/dolphin_color_accent_primary" />
        </shape>
    </item>
</selector>