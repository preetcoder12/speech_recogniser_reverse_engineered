<?xml version="1.0" encoding="utf-8"?>
<layer-list
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape
            android:shape="rectangle">
            <solid
                android:color="?typeBackBackgroundColor" />
            <corners
                android:radius="@dimen/typeback_drag_point_corner_radius" />
            <size
                android:height="@dimen/typeback_drag_point_height"
                android:width="@dimen/typeback_drag_point_width" />
            <stroke
                android:width="1.0dip"
                android:color="?typeBackResizingButtonTintColor" />
        </shape>
    </item>
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/quantum_ic_menu_grey600_18"
            android:tint="?typeBackResizingButtonTintColor" />
    </item>
</layer-list>