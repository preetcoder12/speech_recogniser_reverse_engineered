<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CollapsingToolbar.Settings" parent="@style/Theme.MaterialComponents.DayNight">
        <item name="colorAccent">@color/settingslib_materialColorPrimaryFixed</item>
        <item name="colorPrimary">@color/settingslib_materialColorOnSurfaceInverse</item>
        <item name="elevationOverlayColor">?colorPrimary</item>
        <item name="elevationOverlayEnabled">true</item>
    </style>
    <style name="Seekbar.SettingsLib" parent="@android:style/Widget.Material.SeekBar">
        <item name="android:progressTint">@android:color/system_accent1_100</item>
        <item name="android:progressBackgroundTint">@android:color/system_neutral2_500</item>
        <item name="android:progressBackgroundTintMode">src_over</item>
        <item name="android:thumbTint">@android:color/system_accent1_100</item>
    </style>
    <style name="Theme.DeviceDefault.Dialog.Alert.DayNight" parent="@android:style/Theme.DeviceDefault.Dialog.Alert" />
</resources>
