<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.google.audio.hearing.visualization.accessibility.scribe"
    android:targetSdkVersion="36"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="36" />

    <!-- Microphone access -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Overlay for sound notifications -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- Context for transcriptions -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <!-- External microphone support -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- Foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <!-- Quick settings -->
    <uses-permission android:name="android.permission.BIND_QUICK_SETTINGS_TILE" />

    <permission
        android:name="com.google.audio.hearing.visualization.accessibility.scribe.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.google.audio.hearing.visualization.accessibility.scribe.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name="com.google.audio.hearing.visualization.accessibility.scribe.ScribeApplication"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:label="Live Transcribe"
        android:supportsRtl="true" >

        <!-- ============================================================ -->
        <!-- Accessibility Service (Background listening - Dolphin) -->
        <!-- ============================================================ -->
        <service
            android:name="com.google.audio.hearing.visualization.accessibility.dolphin.DolphinAccessibilityService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE" >
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- ============================================================ -->
        <!-- Foreground Service (Microphone type - high priority) -->
        <!-- ============================================================ -->
        <service
            android:name="com.google.audio.hearing.visualization.accessibility.dolphin.DolphinForegroundService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- ============================================================ -->
        <!-- Quick Settings Tiles -->
        <!-- ============================================================ -->
        <service
            android:name="com.google.audio.hearing.visualization.accessibility.scribe.ScribeTileService"
            android:exported="true"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE" >
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
        <service
            android:name="com.google.audio.hearing.visualization.accessibility.dolphin.DolphinTileService"
            android:exported="true"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE" >
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- ============================================================ -->
        <!-- Main Activity (Scribe - Live Transcribe) -->
        <!-- ============================================================ -->
        <activity
            android:name="com.google.audio.hearing.visualization.accessibility.scribe.MainActivity"
            android:exported="true"
            android:label="Live Transcribe"
            android:windowSoftInputMode="adjustResize" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ============================================================ -->
        <!-- Custom Sound Recording (Personalized sounds) -->
        <!-- ============================================================ -->
        <activity
            android:name="com.google.audio.hearing.visualization.accessibility.dolphin.CustomSoundRecordingActivity"
            android:label="Custom Sound"
            android:windowSoftInputMode="adjustResize" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.google.audio.hearing.visualization.accessibility.scribe.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>